<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - DEFCON Translation Project</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="https://brobin.github.io/hacker-bootstrap/css/hacker.css" rel="stylesheet">
    <style>
        /* Override hacker-bootstrap for BS5 compatibility */
        body {
            background-color: #000;
            color: #0f0;
            font-family: "Courier New", Courier, monospace;
        }

        .navbar {
            background-color: #111 !important;
            border-bottom: 1px solid #0f0;
        }

        .navbar-brand {
            color: #0f0 !important;
            font-weight: bold;
        }

        .nav-link {
            color: #0f0 !important;
            border: 1px solid transparent;
            margin: 0 0.25rem;
        }

        .nav-link:hover, .nav-link.active {
            color: #fff !important;
            background-color: rgba(0, 255, 0, 0.2) !important;
            border-color: #0f0;
        }

        a { color: #0ff; }
        a:hover { color: #0f0; }

        /* Code blocks - improved readability */
        code {
            background-color: #1a1a1a;
            color: #ff0;
            padding: 0.2rem 0.5rem;
            border: 1px solid #333;
            border-radius: 3px;
            font-family: "Courier New", Courier, monospace;
            font-size: 0.9em;
        }

        pre {
            background-color: #0a0a0a;
            border: 1px solid #333;
            padding: 1rem;
            overflow-x: auto;
        }

        pre code {
            background: none;
            border: none;
            padding: 0;
            color: #0f0;
        }

        .btn-primary {
            background-color: #0f0;
            border-color: #0f0;
            color: #000;
        }
        .btn-primary:hover {
            background-color: #0c0;
            border-color: #0c0;
            color: #000;
        }

        .btn-outline-primary {
            border-color: #0f0;
            color: #0f0;
        }
        .btn-outline-primary:hover {
            background-color: #0f0;
            color: #000;
        }

        .card, .panel {
            background-color: #111;
            border-color: #333;
        }

        .card-header {
            background-color: #1a1a1a;
            border-color: #333;
            color: #0f0;
        }

        .table {
            color: #0f0;
        }
        .table-dark {
            background-color: #1a1a1a;
        }
        .table-striped > tbody > tr:nth-of-type(odd) {
            background-color: rgba(0, 255, 0, 0.05);
        }

        .form-control, .form-select {
            background-color: #111;
            border-color: #333;
            color: #0f0;
        }
        .form-control:focus, .form-select:focus {
            background-color: #1a1a1a;
            border-color: #0f0;
            color: #0f0;
            box-shadow: 0 0 0 0.25rem rgba(0, 255, 0, 0.25);
        }

        /* Select dropdown styling */
        .form-select {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%2300ff00' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e");
            cursor: pointer;
        }

        .form-select option {
            background-color: #111;
            color: #0f0;
            padding: 0.5rem;
        }

        .form-select option:hover,
        .form-select option:focus,
        .form-select option:checked {
            background-color: #0f0;
            color: #000;
        }

        /* For better cross-browser select styling */
        select.form-select {
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
        }

        .form-label {
            color: #0f0;
        }

        .alert-info {
            background-color: rgba(0, 255, 255, 0.1);
            border-color: #0ff;
            color: #0ff;
        }
        .alert-success {
            background-color: rgba(0, 255, 0, 0.1);
            border-color: #0f0;
            color: #0f0;
        }
        .alert-warning {
            background-color: rgba(255, 255, 0, 0.1);
            border-color: #ff0;
            color: #ff0;
        }
        .alert-danger {
            background-color: rgba(255, 0, 0, 0.1);
            border-color: #f00;
            color: #f00;
        }

        .badge {
            font-weight: normal;
        }
        .badge.bg-success, .bg-success {
            background-color: #0f0 !important;
            color: #000;
        }
        .badge.bg-warning, .bg-warning {
            background-color: #ff0 !important;
            color: #000;
        }
        .badge.bg-danger, .bg-danger {
            background-color: #f00 !important;
        }
        .badge.bg-secondary, .bg-secondary {
            background-color: #333 !important;
            color: #888;
        }

        .page-link {
            background-color: #111;
            border-color: #333;
            color: #0f0;
        }
        .page-link:hover {
            background-color: #1a1a1a;
            border-color: #0f0;
            color: #0f0;
        }
        .page-item.active .page-link {
            background-color: #0f0;
            border-color: #0f0;
            color: #000;
        }

        .modal-content {
            background-color: #111;
            border-color: #0f0;
        }
        .modal-header, .modal-footer {
            border-color: #333;
        }

        footer {
            margin-top: 2rem;
            padding: 1rem 0;
            border-top: 1px solid #333;
            text-align: center;
            color: #666;
        }

        h1, h2, h3, h4, h5, h6 {
            color: #0f0;
        }

        /* Terminal cursor blink effect for brand */
        .navbar-brand::after {
            content: "_";
            animation: blink 1s step-end infinite;
        }
        @@keyframes blink {
            50% { opacity: 0; }
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">La Villa Hacker</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/files/search">Files</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/conferences">Conferences</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/translations">My Translations</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/stats">Stats</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/help">Help</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <partial name="_LoginPartial" />
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="container">
        <p>
            🏴‍☠️ La Villa Hacker @@ DEFCON |
            <a href="/api/tools/downloader">Download Script</a> |
            <a href="https://github.com/fredyfx/DEFCON-LaVilla-TranslationProject" target="_blank">GitHub</a> |
            Made with &#10084; by <a href="https://github.com/fredyfx" target="_blank">@@fredyfx</a>
        </p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
