@using Microsoft.AspNetCore.Identity
@using System.Security.Claims

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="d-flex align-items-center gap-2">
        <span class="text-success">@User.FindFirst(ClaimTypes.Name)?.Value</span>
        <a href="/Profile" class="btn btn-sm btn-outline-primary" title="Profile">Profile</a>
        <a href="/logout" class="btn btn-sm btn-outline-danger" title="Logout">Logout</a>
    </div>
}
else
{
    <a href="/login" class="btn btn-outline-primary">
        <span>🐙</span> Login with GitHub
    </a>
}
